# All values here are PLACEHOLDERS: fill them in with your own. Copy to `.env.local`.

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of the app (used in Supabase redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Feed engine (Python service in ../feed) ───────────────────────────────────
NEXT_PUBLIC_FEED_WS_URL=ws://localhost:5000/ws
NEXT_PUBLIC_FEED_API_URL=http://localhost:5000
# Shared secret for the internal /vinted/* endpoints (= FEED_INTERNAL_SECRET in
# feed/.env). Server-side only. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FEED_INTERNAL_SECRET=
# Secret to sign the feed access tickets (= FEED_TICKET_SECRET in feed/.env).
FEED_TICKET_SECRET=

# ── Supabase: authentication + database ───────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# PUBLIC key (goes in the browser): sb_publishable_... format
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SECRET key, server-side only (do NOT expose it to the browser): sb_secret_... format
SUPABASE_SECRET_KEY=
