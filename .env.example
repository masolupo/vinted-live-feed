# Config for `docker compose up --build` (local use). Copy to `.env`.
# All values are placeholders.

# ── Supabase (authentication) — Supabase dashboard → Settings → API ───────────
NEXT_PUBLIC_SUPABASE_URL=
# PUBLIC key (goes in the browser): sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SECRET key (server side only): sb_secret_...
SUPABASE_SECRET_KEY=

# ── Shared secrets web ↔ feed ─────────────────────────────────────────────────
# They MUST match the ones in feed/.env. Generate each with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
FEED_INTERNAL_SECRET=
FEED_TICKET_SECRET=
