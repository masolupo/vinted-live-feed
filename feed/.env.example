# ── Vinted scraping ───────────────────────────────────────────────────────────
# Proxy used by the extractors to scrape Vinted (rotating residential).
PROXY=

# URL of the cookie page used to initialize the scraping session.
C_URL=

# Base URL of the Vinted search (catalog/items). The filter querystring is added
# at runtime; this serves as the default feed / base_url.
P_URL=

# Pause (seconds) between catalog requests. The real bottleneck is the proxy
# latency (~2s), so by default no pause (max responsiveness). Raise it only if
# Vinted rate-limits. 0 = no pause.
FEED_FETCH_INTERVAL=0

# Origins allowed for the HTTP calls from the UI (CSV). Default: Next on localhost.
CORS_ORIGINS=http://localhost:3000

# ── Database (Supabase Postgres) — for proxy_pool / vinted_sessions ───────────
# Supabase → Settings → Database → Connection string (Session pooler, port 5432).
DATABASE_URL=

# ── Vinted purchase (session.py / test_buy.py) ────────────────────────────────
# BrightData ISP proxy for login+buy (sticky IP). DIFFERENT from the scraping PROXY.
PROXY_BRD=
# Credentials of the Vinted account to buy from.
VINTED_EMAIL=
VINTED_PASSWORD=
# CapSolver (DataDome bypass during login).
CAPSOLVER_KEY=
# Preferred pickup point (optional: if absent, uses the cheaper home delivery).
PICKUP_POINT_CODE=
PICKUP_POINT_UUID=

# ── Link Vinted account (multi-user fastbuy) ──────────────────────────────────
# Dedicated proxy pool: 1 IP per user. The URL is composed from these 3 parts
# (the zone+IP rows live in the DB, proxy_pool table).
BRD_PROXY_HOST=brd.superproxy.io:33335
BRD_PROXY_USER_PREFIX=brd-customer-hl_xxxxxxxx
BRD_ZONE_PASSWORD=
# Fernet encryption of the Vinted tokens saved in the DB. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VINTED_TOKEN_KEY=
# Shared secret Next ↔ feed (protects the /vinted/* endpoints). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
FEED_INTERNAL_SECRET=
# Secret to sign the feed access tickets (WS + /filters): authorizes only
# logged-in users. Same value in web/.env.local. Generate with token_urlsafe(32).
FEED_TICKET_SECRET=
# Cap on the number of simultaneous pools on the feed (anti-DoS). Default 300.
FEED_MAX_POOLS=300
# Window (seconds) of validity for the per-request signature on /vinted/* (anti-replay).
# Requires synchronized Next/feed clocks (same host or NTP). Default 30.
FEED_SIG_WINDOW_SEC=30

# Per-user rate limiting (max requests / window in seconds). See VLF-04.
VINTED_LOGIN_RATE=5
VINTED_LOGIN_WINDOW=300
VINTED_2FA_RATE=10
VINTED_2FA_WINDOW=300
VINTED_BUY_RATE=20
VINTED_BUY_WINDOW=60

# Fastbuy: maximum distance (meters) for a pickup point that is "not too far".
# Among the pickup couriers it picks the cheapest within this distance; if none
# fall within it, it takes the closest one overall. Default 5000 (5 km).
PICKUP_MAX_DISTANCE_M=5000

# DATABASE_URL (already above) is needed here too for proxy_pool/vinted_sessions.

# Session refresh worker (optional, they have sensible defaults):
# how often the worker checks the DB (seconds, default 5 min)
VINTED_REFRESH_CHECK_INTERVAL=300
# offline keepalive: days BEFORE the refresh_token expiry (default 2)
VINTED_REFRESH_BEFORE_DAYS=2
# online freshness: heartbeat within how many seconds = user "online" (default 10 min)
VINTED_ACTIVE_WINDOW_SEC=600
# refresh access (online) at a random time between MIN and MAX minutes BEFORE the
# expiry (2h): anti-antibot jitter. Default 20–60 min before.
VINTED_ACCESS_MIN_BEFORE_MIN=20
VINTED_ACCESS_MAX_BEFORE_MIN=60
# VLF-07: retention (days) of the buy_debug records (raw payment responses).
# The worker cleans them up periodically. 0 = never delete. Default 30.
VINTED_BUY_DEBUG_DAYS=30
